<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌸 Queenss Garden 👑</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Be Vietnam Pro', sans-serif; }
        body { background: #fdf6f7; padding: 20px; display: flex; justify-content: center; min-height: 100vh; }
        
        .farm-container { 
            width: 100%; 
            max-width: 500px; 
            background: #fff; 
            padding: 25px; 
            border-radius: 30px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.05); 
            display: flex; 
            flex-direction: column; 
        }
        
        h2 { text-align: center; margin-bottom: 20px; color: #ff4d6d; letter-spacing: 0.5px; }

        /* KHU VỰC Ô SEARCH ĐẸP */
        .search-box-pink { background: #fff5f6; border: 2px solid #ffccd5; padding: 12px; border-radius: 15px; margin-bottom: 12px; }
        .search-box-blue { background: #f0f7ff; border: 2px solid #bde0fe; padding: 12px; border-radius: 15px; margin-bottom: 20px; }
        .search-label { font-size: 11px; font-weight: 700; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
        .label-pink { color: #b7094c; }
        .label-blue { color: #003049; }
        
        .farm-input { 
            width: 100%; 
            padding: 12px 14px; 
            font-size: 14px; 
            border-radius: 10px; 
            border: 1px solid #ccc; 
            outline: none; 
            background: #fff; 
            color: #333; 
        }
        .farm-input:focus { border-color: #ff4d6d; }
        
        /* DANH SÁCH HIỂN THỊ THÀNH VIÊN */
        .section-title { font-size: 12px; font-weight: 700; color: #495057; margin-bottom: 12px; text-transform: uppercase; }
        .members-section { flex-grow: 1; }
        
        .card { padding: 15px; border: 1px solid #f0f0f0; border-radius: 20px; margin-bottom: 15px; background: #fff; box-shadow: 0 4px 6px rgba(0,0,0,0.02); }
        .card h3 { font-size: 14px; color: #ff4d6d; margin-bottom: 10px; }
        .chips-container { display: flex; flex-wrap: wrap; gap: 6px; }
        .chip { display: inline-block; padding: 5px 11px; border-radius: 10px; font-size: 11px; background: #fff0f3; border: 1px solid #ffccd5; color: #a4133c; font-weight: 500; }
        
        /* BẢNG HOA XU CHƯA CÓ */
        .missing-section { margin-top: 25px; padding-top: 20px; border-top: 2px dashed #eee; }
        .btn-xu { width: 100%; padding: 12px; background: #f8f9fa; border: 2px solid #e9ecef; border-radius: 12px; color: #495057; font-weight: 700; font-size: 13px; cursor: pointer; text-align: center; }
        .missing-box { margin-top: 12px; padding: 15px; background: #fafafa; border: 1px dashed #dee2e6; border-radius: 15px; display: none; }
        .xu-missing-container { display: flex; flex-wrap: wrap; gap: 6px; }
        .xu-missing { display: inline-block; padding: 5px 11px; border-radius: 10px; font-size: 11px; background: #f8f9fa; border: 1px solid #dee2e6; color: #495057; font-weight: 500; }
    </style>
</head>
<body>

<div class="farm-container">
    <h2>🌸 Queenss Garden 👑</h2>
    
    <div class="search-box-pink">
        <div class="search-label label-pink">🌸 Tìm theo tên hoa:</div>
        <input type="text" id="flowerSearch" class="farm-input" placeholder="Nhập tên hoa để tìm kiếm...">
    </div>
    <div class="search-box-blue">
        <div class="search-label label-blue">👑 Tìm theo tên thành viên:</div>
        <input type="text" id="ownerSearch" class="farm-input" placeholder="Nhập tên thành viên...">
    </div>
    
    <div class="members-section">
        <div class="section-title" id="sectionTitle">📋 Danh sách thành viên:</div>
        <div id="resultArea"></div>
    </div>
    
    <div class="missing-section">
        <button class="btn-xu" id="btnXu">✨ Xem các loại hoa xu hội chưa có</button>
        <div id="missingBox" class="missing-box">
            <div id="missingArea" class="xu-missing-container"></div>
        </div>
    </div>
</div>

<script>
    // Bảng danh sách hoa xu gốc
    const xuFlowersList = ["Thục quỳ đỏ", "Thục quỳ hồng", "Thục quỳ vàng", "Thanh cúc lam", "Mạch môn tím", "Hoa sao nhái trắng", "Hoa baby hồng", "Hoa baby lam", "Hoa lồng đèn đỏ", "Vạn tuế lá xanh", "Trúc đào đỏ tím", "Hải đường đỏ", "Hải đường vàng", "Đỗ quyên hồng", "Đỗ quyên vàng", "Đỗ quyên đỏ", "Tử linh lan hồng", "Tử linh lan đỏ", "Tử linh lan tím", "Hồng jacqueline trắng", "Hoa thúy châu tím", "Hoa thúy châu trắng", "Ghim cài lửa", "Ghim cài vàng mật", "Huệ hosta lam", "Hoa báo xuân hồng", "Hoa huyên tím trắng", "Hoa anh thảo tím nhạt", "Hoa anh thảo xanh nhạt", "Hoa anh thảo hồng nhạt", "Huệ hosta tím", "Mạn đà la", "Nhài nhật", "Lan phượng vĩ đỏ", "Mạch môn hồng phấn", "Hoa lộ vi vàng", "Hoa lộ vi trắng", "Cúc thược dược đen", "Lan vũ nữ vàng", "Hoa poppy himalaya vàng", "Hoa poppy himalaya xanh", "Hoa phi yến tím", "Hoa anh thảo vàng", "Hồng lenten vàng", "Cây sống đời đỏ", "Cây sống đời vàng", "Mộc hương vàng", "Mộc hương trắng", "Thược dược đỏ", "Lay ơn tím", "Tường vi hồng", "Lay ơn trắng", "Hải quỳ cam", "San hô tím", "San hô cam", "Hải quỳ đỏ", "Hoa hải quỳ tím", "Hoa hải quỳ hồng", "Hoa hải quỳ trắng", "Thược dược trắng", "Hồng môn phấn", "Thanh cúc tím", "Lạc tân phụ lam", "Lạc tân phụ đỏ", "Lạc tân phụ tím", "Tỏi trời", "Trúc đào hồng nhạt", "Địa lan trắng", "Hoa hành tím", "Diên đức vĩ trắng vàng", "Hồng lenten đỏ", "Mộc hương cam", "Vạn tuế lá lam", "Thanh cúc hồng"];

    // Bộ dữ liệu chuẩn 100% của hội
    const membersData = [
        { name: "Cá chiên (Anh Kiệt)", flowers: ["Dạ yến thảo lam", "Hoa anh thảo hồng", "Lạp mai đỏ", "Hồng champagne", "Hoa hành tím", "Vạn tuế lá lam", "Diên đức vĩ trắng vàng", "Hồng Lenten đỏ", "Địa lan trắng", "Mộc hương cam", "Gấu bông", "Cây holly vòng xanh", "Bụp hồng cận hồng"] },
        { name: "Tinkerbell (Cẩm Tiên cute)", flowers: ["Đăng tiêu trắng tím", "Đông trùng thông vàng", "Sen trời đầy sao", "Tuyết mai hồng", "Thược dược hồng", "Gấu bông", "Cây holly vòng xanh", "Bụp hồng cận hồng", "Nhụy linh ánh sao", "Hoa bồ câu tím", "Gừng sen bạch ngọc", "Gừng sen ban mai", "Hoa anh thảo vàng", "Hồng lenten đỏ", "Cúc thược dược cam", "Hoa poppy himalaya xanh", "Hồng môn phấn", "Mộc hương cam", "Tử đằng lam", "Cúc indo hồng", "Diên vĩ đức kem đỏ", "Đăng tiêu cam vàng", "Dạ yến thảo lam", "Hoa anh thảo hồng", "Hoa anh thảo xanh", "Hồng champagne", "Mạn châu sa", "San hô xanh", "Ngôi sao bethlehem", "Hoa phi yến tím", "Mộc lan ngọc ngà", "Lạp mai hương phi", "Phù dung tím hộp báu", "Thọ ngọc ôm ánh sáng", "Hạc gửi ngân hà", "Tử linh phúc lộc", "Đế vương xích diễm", "Gấu hoa hồng", "Có rồng ắt lính", "Hạnh nguyệt nghỉ dưới bóng hoa", "Lạc tân phụ lam", "Lạc tân phụ đỏ", "Thanh cúc hồng", "Lạc tân phụ tím", "Thục quỳ hồng", "Tỏi trời", "Thanh cúc lam", "Hoa baby trắng", "Trúc đào hồng nhạt", "Ghim cài vàng mật", "Hoa báo xuân hồng", "Hoa huyên tím trắng", "Hoa anh thảo xanh nhạt"] }
    ];

    const resultArea = document.getElementById('resultArea');
    const missingArea = document.getElementById('missingArea');
    const missingBox = document.getElementById('missingBox');
    const flowerInput = document.getElementById('flowerSearch');
    const ownerInput = document.getElementById('ownerSearch');

    // Hàm render tìm kiếm đa năng cực nhạy, không lỗi chữ hoa chữ thường
    function renderMembers() {
        resultArea.innerHTML = "";
        const fKey = flowerInput.value.toLowerCase().trim();
        const oKey = ownerInput.value.toLowerCase().trim();
        
        membersData.forEach(m => {
            // Kiểm tra điều kiện tìm kiếm theo tên thành viên
            const matchOwner = m.name.toLowerCase().includes(oKey);
            
            // Lọc danh sách hoa của thành viên dựa trên ô tìm kiếm hoa
            const filteredFlowers = m.flowers.filter(f => {
                return f.toLowerCase().includes(fKey);
            });
            
            // Nếu thỏa mãn bộ lọc thành viên và thành viên đó có hoa tương ứng
            if (matchOwner && filteredFlowers.length > 0) {
                // Sắp xếp danh sách hoa theo bảng chữ cái A-Z
                const sortedFlowers = [...new Set(filteredFlowers)].sort((a, b) => a.localeCompare(b));
                
                let html = `<div class="card"><h3>👑 ${m.name}</h3><div class="chips-container">`;
                sortedFlowers.forEach(f => {
                    html += `<span class="chip">${f}</span>`;
                });
                html += `</div></div>`;
                resultArea.innerHTML += html;
            }
        });
        
        if (resultArea.innerHTML === "") {
            resultArea.innerHTML = `<div style="text-align:center; font-size:13px; color:#999; padding:20px;">❌ Không tìm thấy kết quả phù hợp...</div>`;
        }
    }

    // Hàm cập nhật danh sách hoa xu hội chưa sở hữu an toàn tuyệt đối
    function updateMissingXu() {
        // Gom toàn bộ hoa thành viên đã sở hữu và chuyển hết về chữ thường để loại trừ chính xác
        const ownedSet = new Set();
        membersData.forEach(m => {
            m.flowers.forEach(f => ownedSet.add(f.toLowerCase().trim()));
        });
        
        // Lọc danh sách hoa xu chưa có bằng cách so sánh chuỗi chữ thường
        const missing = xuFlowersList.filter(xu => !ownedSet.has(xu.toLowerCase().trim()));
        
        // Sắp xếp hoa xu chưa có từ A-Z
        missing.sort((a, b) => a.localeCompare(b));
        
        missingArea.innerHTML = missing.map(f => `<span class="xu-missing">${f}</span>`).join('');
    }

    // Đóng mở bảng hoa xu mượt mà bằng EventListener
    document.getElementById('btnXu').addEventListener('click', function() {
        if (missingBox.style.display === "block") {
            missingBox.style.display = "none";
        } else {
            missingBox.style.display = "block";
            setTimeout(() => { missingBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 50);
        }
    });

    // Lọc tự động ngay khi gõ vào ô Input
    flowerInput.addEventListener('input', renderMembers);
    ownerInput.addEventListener('input', renderMembers);

    // Chạy đồng bộ hệ thống ngay khi load trang
    updateMissingXu();
    renderMembers();
</script>
</body>
</html>
