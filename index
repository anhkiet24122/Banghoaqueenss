<div class="farm-container">
    <h2>🌸 Queenss Garden 👑</h2>
    
    <div class="search-box-pink">
        <div class="search-label label-pink">🌸 Tìm theo tên hoa:</div>
        <input type="text" id="flowerSearch" class="farm-input" placeholder="Nhập tên hoa để xem ai sở hữu...">
    </div>
    <div class="search-box-blue">
        <div class="search-label label-blue">👑 Tìm theo tên thành viên:</div>
        <input type="text" id="ownerSearch" class="farm-input" placeholder="Nhập tên thành viên...">
    </div>
    
    <div class="members-section">
        <div class="section-title" id="sectionTitle">📋 Danh sách thành viên:</div>
        <div id="resultArea"></div>
    </div>
    
    <div class="missing-section">
        <button class="btn-xu" id="btnXu">✨ Xem các loại hoa xu hội chưa có</button>
        <div id="missingBox" class="missing-box">
            <div id="missingArea" class="xu-missing-container"></div>
