    // Thứ tự phân tầng: Xanh lá (1) -> Tím (2) -> Cam (3) -> Hồng (4)
    function getFlowerWeight(flowerName) {
        const name = flowerName.toLowerCase().trim();
        if (PINK_LIST.includes(name)) return { score: 4, className: 'tier-pink' };
        if (ORANGE_LIST.includes(name)) return { score: 3, className: 'tier-orange' };
        if (GREEN_LIST.includes(name)) return { score: 1, className: 'tier-green' };
        return { score: 2, className: 'tier-purple' };
    }

    function initRenderRankList() {
        mainRankArea.innerHTML = "";
        const totalMembers = membersData.length;
        mainRankArea.innerHTML = `<div style="font-size: 12px; font-weight: 700; color: #40916c; margin-bottom: 14px; background: #d8f3dc; padding: 6px 14px; border-radius: 12px; display: inline-block; border: 1px solid #b7e4c7;">🌱 Tổng số: ${totalMembers} thành viên</div>`;
        
        const container = document.createElement('div');
        container.style.cssText = "display: flex; flex-direction: column; gap: 12px; width: 100%;";

        const sortedRank = membersData.map(m => {
            const uniqueFlowers = [...new Set(m.flowers)].sort((a, b) => a.localeCompare(b, 'vi'));
            return { name: m.name, rawFlowers: uniqueFlowers, count: uniqueFlowers.length };
        }).sort((a, b) => b.count - a.count);

        sortedRank.forEach((item, index) => {
            const rankNum = index + 1;
            const collapseItem = document.createElement('div');
            let isBoy = item.name.includes("Cá chiên") || item.name.includes("Sun (Thắng)") || item.name.includes("ChồgcủaHạDi");
            
            collapseItem.style.cssText = "border: 1px solid #ffe3e8; border-radius: 20px; overflow: hidden; background: #fff; box-shadow: 0 4px 10px rgba(255, 182, 193, 0.08); transition: all 0.3s;";
            
            if (isBoy) {
                collapseItem.style.cssText = "border: 1px solid #bde0fe; border-radius: 20px; overflow: hidden; background: #fff; box-shadow: 0 4px 10px rgba(0, 48, 73, 0.04); transition: all 0.3s;";
                collapseItem.className = "cute-rank-item gentleman-card-style";
            } else {
                collapseItem.className = "cute-rank-item";
            }

            // Sắp xếp ép buộc từ phẩm cao xuống phẩm thấp trong túi đồ: Hồng (4) -> Cam (3) -> Tím (2) -> Xanh lá (1)
            const sortedFlowersWithTier = item.rawFlowers.map(f => {
                const info = getFlowerWeight(f);
                return { name: f, score: info.score, className: info.className };
            }).sort((a, b) => {
                if (b.score !== a.score) return b.score - a.score; 
                return a.name.localeCompare(b.name, 'vi'); 
            });

            let pinkCount = 0;
            let orangeCount = 0;
            let greenCount = 0;
            let purpleCount = 0;
            let chipsHtml = '';

            sortedFlowersWithTier.forEach(f => {
                if (f.score === 4) pinkCount++;
                if (f.score === 3) orangeCount++;
                if (f.score === 2) purpleCount++;
                if (f.score === 1) greenCount++;
                chipsHtml += `<span class="flower-chip-item ${f.className}">${capitalizeFirstLetter(f.name)}</span>`;
            });

            // Thống kê sức mạnh
            let summaryHtml = `<div class="summary-rarity-line">👑 <strong>Đội hình sức mạnh:</strong> `;
            let parts = [];
            if (pinkCount > 0) parts.push(`<span style="color:#a4133c; font-weight:700;">${pinkCount} Hồng</span>`);
            if (orangeCount > 0) parts.push(`<span style="color:#e65100; font-weight:700;">${orangeCount} Cam</span>`);
            if (purpleCount > 0) parts.push(`<span style="color:#5f3dc4; font-weight:700;">${purpleCount} Tím</span>`);
            if (greenCount > 0) parts.push(`<span style="color:#2d6a4f; font-weight:700;">${greenCount} Xanh Lá</span>`);
            
            if (parts.length > 0) {
                summaryHtml += parts.join(' | ') + `</div>`;
            } else {
                summaryHtml += `Chưa có hoa phẩm chất.</div>`;
            }

            let icon = isBoy ? '🎩' : '👑';
            let nameColorStyle = isBoy ? "color: #003049; font-weight:700;" : "color: #4a4a4a;";
            let badgeColorStyle = isBoy ? "color: #003049; background: #e0f2fe; border: 1px solid #bae6fd;" : "color: #ff4d6d; background: #fff5f6; border: 1px solid #ffccd5;";
            
            let numColor = "#d6ccc2";
            if (rankNum === 1) numColor = "#ffb703";
            if (rankNum === 2) numColor = "#fb8500";
            if (rankNum === 3) numColor = "#219ebc";

            collapseItem.innerHTML = `
                <div class="click-header-line" style="display: flex; justify-content: space-between; align-items: center; padding: 15px 18px; cursor: pointer; user-select: none; transition: background 0.2s;">
