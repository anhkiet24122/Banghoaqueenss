        { name: "Hải Đường (Thanh Ngân)", flowers: ["Trái tim đá quý", "Mộc lan ngọc ngà", "Cá heo hồng", "Hoa hành tím", "Lan phượng vĩ đỏ", "Hoa poppy himalaya xanh", "San hô tím", "Hoa poppy tím", "Hoa lồng đèn cam", "Lan vũ nữ cam", "Dạ yến thảo lam", "Hồng champagne", "Cúc thược dược cam", "Gấu bông", "Cây holly vòng xanh", "Bụp hồng cận hồng", "Hoa anh thảo hồng", "Hoa anh thảo xanh", "Ngôi sao bethlehem"] },
        { name: "Mina (Mỹ Anh)", flowers: ["Ngân hà chiếu nhụy", "Mộc lan ngọc ngà", "Dạ yến thảo lam", "Hoa anh thảo hồng", "Lạp mai đỏ", "Hồng champagne", "Địa lan trắng", "Mạn đà la", "San hô tím", "Hoa poppy cam", "Thược dược trắng", "Lay ơn tím", "Gấu bông", "Cây holly vòng xanh", "Bụp hồng cận hồng", "Lạc tân phụ lam", "Lạc tân phụ đỏ", "Thanh cúc tím", "Thanh cúc hồng", "Lạc tân phụ tím", "Tỏi trời"] },
        { name: "Sương (Sương)", flowers: ["Lạp mai đỏ", "Bụp hồng cận hồng", "Dạ yến thảo lam", "Hoa anh thảo xanh", "Hồng champagne", "Hoa lộ vi vàng", "Mộc hương cam", "Gấu bông", "Cây holly vòng xanh", "Mộc lan ngọc ngà", "Trúc đào hồng nhạt", "Tỏi trời"] },
        { name: "Mẫn hoa (Thảo Vy)", flowers: ["Dạ yến thảo lam", "Hoa anh thảo hồng", "Lạp mai đỏ", "Mạn châu sa", "San hô xanh", "Ngôi sao bethlehem", "Lan phượng vĩ đỏ", "Hồng lenten vàng", "Mạch môn hồng phấn", "Hoa lộ vi trắng", "Hoa hải quỳ hồng", "Hoa poppy tím", "Hoa poppy đỏ", "Hoa poppy cam", "Cúc indo hồng", "Diên vĩ đức hồng tím", "Hồng lenten hồng", "Mạch môn sương trắng", "Hoa sao nhái tím", "Lay ơn vàng", "Thược dược hồng", "Gấu bông", "Cây holly vòng xanh", "Bụp hồng cận hồng", "Loa kèn peru đỏ", "Đông trùng thông vàng", "Đông trùng thông tím", "Hoa thụy hương trắng tuyết", "Hoa huệ mưa thanh nhã", "Hoa mặt rồng hồng phấn", "Hồng cecil lam", "Sắc cam mùa xuân", "Mẫu đơn ánh ngọc", "Nguyệt quý mây hồng", "Nguyệt quý mây vàng", "Hương hoa diên vĩ", "Cúc mẫu đơn tím nho", "Trái tim tìm mật", "Trái tim đá quý", "Ngân hà chiếu nhụy", "Hạnh nguyệt nghỉ dưới bóng hoa", "Trái tim mộng ảo"] }
    ];

    const xuFlowersList = rawXuList.map(item => cleanFormat(item));
    const membersData = rawMembers.map(m => ({
        name: m.name,
        flowers: m.flowers.map(f => cleanFormat(f))
    }));

    const mainRankArea = document.getElementById('mainRankArea');
    const searchResultArea = document.getElementById('searchResultArea');
    const missingArea = document.getElementById('missingArea');
    const missingBox = document.getElementById('missingBox');
    const rankBox = document.getElementById('rankBox');
    const helpBox = document.getElementById('helpBox');
    const chibiArtBox = document.getElementById('chibiArtBox');
    const flowerInput = document.getElementById('flowerSearch');
    const defaultGardenWidgets = document.getElementById('defaultGardenWidgets');
    const searchViewArea = document.getElementById('searchViewArea');

    function getOwnersOfFlower(lowerFlowerName) {
        return membersData.filter(m => m.flowers.includes(lowerFlowerName)).map(m => m.name);
    }

    function buildRankList() {
        mainRankArea.innerHTML = "";
        const totalMembers = membersData.length;
        mainRankArea.innerHTML = `<div style="font-size: 12px; font-weight: 700; color: #40916c; margin-bottom: 14px; background: #d8f3dc; padding: 6px 14px; border-radius: 12px; display: inline-block; border: 1px solid #b7e4c7;">🌱 Tổng số hoa của hội: ${totalMembers} thành viên</div>`;
        
        const container = document.createElement('div');
        container.style.cssText = "display: flex; flex-direction: column; gap: 12px; width: 100%;";

        const sortedRank = membersData.map(m => {
            const uniqueFlowers = [...new Set(m.flowers)].sort((a, b) => a.localeCompare(b, 'vi'));
            return { name: m.name, rawFlowers: uniqueFlowers, count: uniqueFlowers.length };
        }).sort((a, b) => b.count - a.count);

        sortedRank.forEach((item, index) => {
            const rankNum = index + 1;
            const collapseItem = document.createElement('div');
            let isBoy = item.name.includes("Cá chiên");
            
            collapseItem.style.cssText = "border: 1px solid #ffe3e8; border-radius: 20px; overflow: hidden; background: #fff; box-shadow: 0 4px 10px rgba(255, 182, 193, 0.08); transition: all 0.3s;";
            if (isBoy) {
                collapseItem.style.cssText = "border: 1px solid #bde0fe; border-radius: 20px; overflow: hidden; background: #fff; box-shadow: 0 4px 10px rgba(0, 48, 73, 0.04); transition: all 0.3s;";
                collapseItem.className = "cute-rank-item gentleman-card-style";
            } else {
                collapseItem.className = "cute-rank-item";
            }

            let chipsHtml = '';
            item.rawFlowers.forEach(f => {
                chipsHtml += `<span class="flower-chip-item">${capitalizeFirstLetter(f)}</span>`;
            });

            let icon = isBoy ? '🎩' : '👑';
            let nameColorStyle = isBoy ? "color: #003049; font-weight:700;" : "color: #4a4a4a;";
            let badgeColorStyle = isBoy ? "color: #003049; background: #e0f2fe; border: 1px solid #bae6fd;" : "color: #ff4d6d; background: #fff5f6; border: 1px solid #ffccd5;";
            
            let numColor = "#d6ccc2";
            if (rankNum === 1) numColor = "#ffb703";
            if (rankNum === 2) numColor = "#fb8500";
            if (rankNum === 3) numColor = "#219ebc";

            collapseItem.innerHTML = `
                <div class="click-header-line" style="display: flex; justify-content: space-between; align-items: center; padding: 15px 18px; cursor: pointer; user-select: none; transition: background 0.2s;">
                    <div style="display: flex; align-items: center; gap: 10px; font-size: 13.5px; ${nameColorStyle}">
                        <span style="font-weight: 700; color: ${numColor}; width: 24px; text-align: center; font-size: 14px;">#${rankNum}</span>
                        <span>${icon} ${item.name}</span>
                    </div>
                    <span class="rank-badge-pill" style="font-weight: 700; padding: 5px 12px; border-radius: 20px; font-size: 11px; ${badgeColorStyle}">${item.count} loại hoa</span>
                </div>
                <div class="rank-content-box">
                    <div style="display: flex; flex-wrap: wrap; gap: 4px;">${chipsHtml}</div>
                </div>
            `;

            collapseItem.querySelector('.click-header-line').addEventListener('click', function() {
                collapseItem.classList.toggle('active-folder');
            });

            container.appendChild(collapseItem);
        });

        mainRankArea.appendChild(container);
    }

    function searchFlowerLogic() {
        const fKey = flowerInput.value.toLowerCase().trim();
        
        if (fKey !== "") {
            defaultGardenWidgets.style.display = "none";
            searchViewArea.style.display = "block";
            
            let matchedLowerSet = new Set();
            membersData.forEach(m => {
                m.flowers.forEach(f => { if (f.includes(fKey)) matchedLowerSet.add(f); });
            });
            xuFlowersList.forEach(xu => { if (xu.includes(fKey)) matchedLowerSet.add(xu); });

            const sortedMatches = Array.from(matchedLowerSet).sort((a, b) => a.localeCompare(b, 'vi'));

            if (sortedMatches.length > 0) {
                let htmlWrapper = '<div class="flower-stacked-results" style="display: flex; flex-direction: column; gap: 14px; width: 100%;">';
                sortedMatches.forEach(lowerFlowerName => {
                    const ownersList = getOwnersOfFlower(lowerFlowerName);
                    let displayTitle = capitalizeFirstLetter(lowerFlowerName);
                    if (displayTitle.toLowerCase().startsWith("hoa ")) {
                        displayTitle = displayTitle.slice(4);
                        displayTitle = capitalizeFirstLetter(displayTitle);
                    }

                    if (ownersList.length > 0) {
                        htmlWrapper += `
                            <div class="single-flower-block" style="padding: 18px; border: 2.5px solid #ffccd5; border-radius: 24px; background: #fff5f6; color: #b7094c; font-size: 13.5px; line-height: 1.6; box-shadow: 0 6px 15px rgba(255,182,193,0.12);">
                                🌸 Hoa <strong>${displayTitle}</strong> hiện có <strong>${ownersList.length}</strong> thành viên sở hữu:<br>
                                👉 <em>${ownersList.join(', ')}</em>
                            </div>`;
                    } else {
                        htmlWrapper += `
                            <div class="single-flower-block" style="padding: 18px; border: 2.5px solid #dee2e6; border-radius: 24px; background: #fafafa; color: #888; font-size: 13.5px; line-height: 1.6;">
                                🌸 Hoa <strong>${displayTitle}</strong>: Hiện chưa có thành viên nào sở hữu.
                            </div>`;
                    }
                });
                htmlWrapper += '</div>';
                searchResultArea.innerHTML = htmlWrapper;
            } else {
                searchResultArea.innerHTML = `<div class="single-flower-block" style="padding: 18px; border: 2.5px solid #dee2e6; border-radius: 24px; background: #fafafa; color: #999; text-align:center; font-size: 13.5px;">❌ Không tìm thấy loại hoa nào chứa từ khóa "${flowerInput.value}"</div>`;
            }
        } else {
            searchViewArea.style.display = "none";
            defaultGardenWidgets.style.display = "flex";
        }
    }

    function updateMissingXu() {
        const ownedSet = new Set();
        membersData.forEach(m => m.flowers.forEach(f => ownedSet.add(f)));
        const missing = xuFlowersList.filter(xu => !ownedSet.has(xu));
        const uniqueMissing = [...new Set(missing)].sort((a, b) => a.localeCompare(b, 'vi'));
        missingArea.innerHTML = uniqueMissing.map(f => `<span class="xu-missing-badge">${capitalizeFirstLetter(f)}</span>`).join('');
    }

    document.getElementById('btnHelp').addEventListener('click', function() {
        if (helpBox.style.display === "block") {
            helpBox.style.display = "none";
            chibiArtBox.style.display = "block"; // Hiện lại tranh khi đóng hướng dẫn
        } else {
            helpBox.style.display = "block";
            rankBox.style.display = "none";
            missingBox.style.display = "none";
            chibiArtBox.style.display = "none"; // Ẩn tranh khi mở hướng dẫn
            setTimeout(() => { helpBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 80);
        }
    });

    document.getElementById('btnRank').addEventListener('click', function() {
        if (rankBox.style.display === "block") {
            rankBox.style.display = "none";
            chibiArtBox.style.display = "block"; // Hiện lại tranh khi đóng BXH
        } else {
            rankBox.style.display = "block";
            helpBox.style.display = "none";
            missingBox.style.display = "none"; 
            chibiArtBox.style.display = "none"; // Ẩn tranh khi mở BXH
            buildRankList();
            setTimeout(() => { rankBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 80);
        }
    });

    document.getElementById('btnXu').addEventListener('click', function() {
        if (missingBox.style.display === "block") {
            missingBox.style.display = "none";
            chibiArtBox.style.display = "block"; // Hiện lại tranh khi đóng Hoa Xu
        } else {
            missingBox.style.display = "block";
            helpBox.style.display = "none";
            rankBox.style.display = "none"; 
            chibiArtBox.style.display = "none"; // Ẩn tranh khi mở Hoa Xu
            setTimeout(() => { missingBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 80);
        }
    });

    flowerInput.addEventListener('input', searchFlowerLogic);
    updateMissingXu();
</script>
</body>
