    const xuFlowersConfig = [
        { name: "Thục quỳ hồng", owners: ["Cá chiên", "Cá nướng"] },
        { name: "Hoa xu 1", owners: ["A Ân Diệu"] },
        { name: "Hoa xu 2", owners: ["Candy"] },
        { name: "Hoa xu 3", owners: ["Mẫn Hoa"] }
    ];

    membersData.sort((a,b) => a.name.localeCompare(b.name));
    const flowersMap = {};
    membersData.forEach(m => m.flowers.forEach(f => {
        if(!flowersMap[f]) flowersMap[f] = [];
        flowersMap[f].push(m.name);
    }));
    const flowersData = Object.keys(flowersMap).sort().map(f => ({ flowerName: f, owners: flowersMap[f].sort() }));

    function normalizeStr(str) { return str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase(); }

    function displayResults(data, type) {
        const resultList = document.getElementById('resultList');
        resultList.innerHTML = "";
        document.getElementById('resultHeader').innerHTML = data.length > 0 ? "🌟 Kết quả tìm kiếm:" : "";
        
        if(data.length === 0) { resultList.innerHTML = `<li class="welcome-box">Không tìm thấy kết quả nào... 🌸</li>`; return; }

        data.forEach(item => {
            const li = document.createElement('li');
            li.className = 'inventory-card';
            if(type === 'flower') {
                li.innerHTML = `<div class="card-top"><span class="card-name">${item.flowerName}</span><span class="card-badge">${item.owners.length} bạn</span></div><div class="chips-container">${item.owners.map(o => `<span class="farm-chip">${o}</span>`).join('')}</div>`;
            } else {
                li.innerHTML = `<div class="card-top"><span class="card-name">👑 ${item.name}</span><span class="card-badge">${item.flowers.length} loại</span></div><div class="chips-container">${item.flowers.sort().map(f => `<span class="farm-chip">${f}</span>`).join('')}</div>`;
            }
            resultList.appendChild(li);
        });
    }

    document.getElementById('flowerSearch').addEventListener('input', (e) => {
        const k = normalizeStr(e.target.value);
        if(k) { document.getElementById('ownerSearch').value = ""; displayResults(flowersData.filter(i => normalizeStr(i.flowerName).includes(k)), 'flower'); }
    });

    document.getElementById('ownerSearch').addEventListener('input', (e) => {
        const k = normalizeStr(e.target.value);
        if(k) { document.getElementById('flowerSearch').value = ""; displayResults(membersData.filter(i => normalizeStr(i.name).includes(k)), 'owner'); }
    });

    function showXuList() {
        document.getElementById('flowerSearch').value = "";
        document.getElementById('ownerSearch').value = "";
        document.getElementById('resultHeader').innerHTML = "✨ Bảng tổng hợp Hoa Xu:";
        document.getElementById('resultList').innerHTML = "";
        
        xuFlowersConfig.forEach(xu => {
            const li = document.createElement('li');
            li.className = 'inventory-card';
            li.style.border = "1px solid #ffe599";
            li.style.background = "#fffdf5"; 
            li.innerHTML = `
                <div class="card-top" style="margin-bottom: 8px;">
                    <span class="card-name" style="color:#b57b00; font-size: 16px;">🌻 ${xu.name}</span>
                </div>
                <div style="font-size: 11px; color: #888; margin-bottom: 10px;">Sở hữu bởi:</div>
                <div class="chips-container">
                    ${xu.owners.map(o => `
                        <span class="farm-chip" style="border:1px solid #ffd8a8; background:#fff3bf; color:#854d0e; font-weight:600; padding: 6px 12px;">
                            👑 ${o}
                        </span>
                    `).join('')}
                </div>
            `;
            document.getElementById('resultList').appendChild(li);
        });
    }
</script>
