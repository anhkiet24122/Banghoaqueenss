        { name: "Mina (Mỹ Anh)", flowers: ["Ngân hà chiếu nhụy", "Mộc lan ngọc ngà", "Dạ yến thảo lam", "Hoa anh thảo hồng", "Lạp mai đỏ", "Hồng champagne", "Địa lan trắng", "Mạn đà la", "San hô tím", "Hoa poppy cam", "Thược dược trắng", "Lay ơn tím", "Gấu bông", "Cây holly vòng xanh", "Bụp hồng cận hồng", "Lạc tân phụ lam", "Lạc tân phụ đỏ", "Thanh cúc tím", "Thanh cúc hồng", "Lạc tân phụ tím", "Tỏi trời"] }
    ];
        // Bạn copy toàn bộ mảng rawMembers từ file cũ của bạn vào đây
    ];

    const xuFlowersList = rawXuList.map(item => cleanFormat(item));
    const membersData = rawMembers.map(m => ({
        name: m.name,
        flowers: m.flowers.map(f => cleanFormat(f)),
        flowerCount: 0
    })).map(m => {
        m.flowerCount = [...new Set(m.flowers)].length;
        return m;
    });

    // ================== DOM ELEMENTS ==================
    const resultArea = document.getElementById('resultArea');
    const missingArea = document.getElementById('missingArea');
    const missingBox = document.getElementById('missingBox');
    const flowerInput = document.getElementById('flowerSearch');
    const ownerInput = document.getElementById('ownerSearch');
    const statsArea = document.getElementById('statsArea');
    const darkToggle = document.getElementById('darkModeToggle');

    let isDarkMode = false;

    // ================== FUNCTIONS ==================
    function getOwnersOfFlower(flowerName) {
        const target = flowerName.toLowerCase().trim();
        return membersData.filter(m => m.flowers.some(f => f.toLowerCase().trim() === target)).map(m => m.name);
    }

    function debounce(fn, delay = 280) {
        let timeout;
        return (...args) => {
            clearTimeout(timeout);
            timeout = setTimeout(() => fn(...args), delay);
        };
    }

    function updateStats() {
        const totalMembers = membersData.length;
        const totalUniqueFlowers = new Set(membersData.flatMap(m => m.flowers)).size;
        const ownedXu = xuFlowersList.filter(xu => 
            membersData.some(m => m.flowers.some(f => f.toLowerCase() === xu.toLowerCase()))
        ).length;

        statsArea.innerHTML = `
            👥 <strong>${totalMembers}</strong> thành viên • 
            🌸 <strong>${totalUniqueFlowers}</strong> loại hoa • 
            ✨ <strong>${ownedXu}/${xuFlowersList.length}</strong> hoa xu đã có
        `;
    }

    function renderMembers() {
        resultArea.innerHTML = "";
        const fKey = flowerInput.value.toLowerCase().trim();
        const oKey = ownerInput.value.toLowerCase().trim();

        if (fKey !== "") {
            ownerInput.value = "";
            let matchedSet = new Set();

            membersData.forEach(m => {
                m.flowers.forEach(f => { if (f.toLowerCase().includes(fKey)) matchedSet.add(f); });
            });
            xuFlowersList.forEach(xu => { if (xu.toLowerCase().includes(fKey)) matchedSet.add(xu); });

            const sortedMatches = Array.from(matchedSet).sort((a, b) => a.localeCompare(b, 'vi'));

            if (sortedMatches.length > 0) {
                let html = '<div class="flower-result-container">';
                sortedMatches.forEach(flowerName => {
                    const ownersList = getOwnersOfFlower(flowerName);
                    let displayTitle = flowerName.replace(/^Hoa /i, '');

                    if (ownersList.length > 0) {
                        html += `
                            <div class="summary-result">
                                🌸 <strong>${displayTitle}</strong> được sở hữu bởi <strong>${ownersList.length}</strong> thành viên:<br>
                                👉 <em>${ownersList.join(', ')}</em>
                            </div>`;
                    } else {
                        html += `
                            <div class="summary-result" style="color:#888; border-color:#dee2e6; background:#fafafa;">
                                🌸 <strong>${displayTitle}</strong>: Chưa có ai trong hội sở hữu.
                            </div>`;
                    }
                });
                html += '</div>';
                resultArea.innerHTML = html;
            } else {
                resultArea.innerHTML = `<div class="summary-result" style="text-align:center; color:#999;">❌ Không tìm thấy hoa nào chứa "${flowerInput.value}"</div>`;
            }
            return;
        }

        // Hiển thị danh sách thành viên (có search hoặc mặc định)
        const filteredMembers = oKey ? 
            membersData.filter(m => m.name.toLowerCase().includes(oKey)) :
            [...membersData].sort((a, b) => b.flowerCount - a.flowerCount);

        if (filteredMembers.length === 0) {
            resultArea.innerHTML = `<div style="text-align:center; padding:30px; color:#999;">Không tìm thấy thành viên nào...</div>`;
            return;
        }

        filteredMembers.forEach(m => {
            const uniqueFlowers = [...new Set(m.flowers)].sort((a, b) => a.localeCompare(b, 'vi'));
            let html = `<div class="card">
                <h3>👑 ${m.name} <small style="color:#888; font-weight:400;">(${m.flowerCount} hoa)</small></h3>
                <div class="chips-container">`;
            uniqueFlowers.forEach(f => { 
                html += `<span class="chip">${f}</span>`; 
            });
            html += `</div></div>`;
            resultArea.innerHTML += html;
        });
    }

    function updateMissingXu() {
        const ownedSet = new Set(membersData.flatMap(m => m.flowers.map(f => f.toLowerCase().trim())));
        const missing = xuFlowersList.filter(xu => !ownedSet.has(xu.toLowerCase().trim()));
        missingArea.innerHTML = missing.sort((a, b) => a.localeCompare(b, 'vi'))
            .map(f => `<span class="xu-missing">${f}</span>`).join('');
    }

    // ================== EVENT LISTENERS ==================
    const debouncedRender = debounce(renderMembers);

    flowerInput.addEventListener('input', debouncedRender);
    ownerInput.addEventListener('input', debouncedRender);

    document.getElementById('clearFlower').addEventListener('click', () => {
        flowerInput.value = '';
        debouncedRender();
    });

    document.getElementById('clearOwner').addEventListener('click', () => {
        ownerInput.value = '';
        debouncedRender();
    });

    document.getElementById('btnXu').addEventListener('click', () => {
        missingBox.style.display = missingBox.style.display === "block" ? "none" : "block";
    });

    darkToggle.addEventListener('click', () => {
        isDarkMode = !isDarkMode;
        document.body.classList.toggle('dark-mode', isDarkMode);
        darkToggle.textContent = isDarkMode ? '☀️' : '🌙';
    });

    // ================== INIT ==================
    updateStats();
    updateMissingXu();
    renderMembers();
</script>
</body>
</html>
