<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌸 Queenss Garden 👑</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght=400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Be Vietnam Pro', sans-serif; }
        body { background: #fdf6f7; padding: 20px; display: flex; justify-content: center; min-height: 100vh; }
        
        .farm-container { 
            width: 100%; 
            max-width: 500px; 
            background: #fff; 
            padding: 25px; 
            border-radius: 30px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.05); 
            display: flex; 
            flex-direction: column; 
        }
        
        h2 { text-align: center; margin-bottom: 25px; color: #ff4d6d; letter-spacing: 0.5px; font-size: 24px; }

        /* Ô TÌM KIẾM THEO TÊN HOA (ĐÃ XÓA HOÀN TOÀN Ô THÀNH VIÊN) */
        .search-box-pink { background: #fff5f6; border: 2px solid #ffccd5; padding: 14px; border-radius: 20px; margin-bottom: 25px; }
        .search-label { font-size: 11px; font-weight: 700; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
        .label-pink { color: #b7094c; }
        
        .farm-input { 
            width: 100%; 
            padding: 12px 14px; 
            font-size: 14px; 
            border-radius: 12px; 
            border: 1px solid #ccc; 
            outline: none; 
            background: #fff; 
            color: #333; 
        }
        .farm-input:focus { border-color: #ff4d6d; }
        
        /* DANH SÁCH HIỂN THỊ CHÍNH */
        .section-title { font-size: 13px; font-weight: 700; color: #495057; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 0.5px; }
        .members-section { flex-grow: 1; }
        
        /* ĐỊNH DẠNG BẢNG XẾP HẠNG THÀNH VIÊN MÀN HÌNH CHÍNH */
        .rank-container { display: flex; flex-direction: column; gap: 8px; background: #fff; border: 1px solid #f5f5f5; padding: 15px; border-radius: 20px; }
        .member-count-badge { font-size: 13px; font-weight: 700; color: #b7094c; margin-bottom: 12px; background: #fff0f3; padding: 8px 12px; border-radius: 10px; display: inline-block; width: max-content; }
        .rank-item { display: flex; justify-content: space-between; align-items: center; padding: 11px 14px; border-radius: 12px; background: #fafafa; border: 1px solid #f0f0f0; font-size: 13px; font-weight: 500; }
        .rank-item-left { display: flex; align-items: center; gap: 8px; color: #333; }
        .rank-number { font-weight: 700; color: #aaa; width: 20px; }
        .rank-top1 .rank-number { color: #ffb703; }
        .rank-top2 .rank-number { color: #fb8500; }
        .rank-top3 .rank-number { color: #219ebc; }
        .rank-flower-count { font-weight: 700; color: #ff4d6d; background: #fff; padding: 4px 10px; border-radius: 20px; border: 1px solid #ffccd5; font-size: 12px; }

        /* ĐỊNH DẠNG THÈ TIÊN ĐÓNG MỞ (KHI BẤM NÚT ĐÁY TRANG) */
        .member-collapse-item { border: 1px solid #f0f0f0; border-radius: 16px; margin-bottom: 10px; overflow: hidden; background: #fff; box-shadow: 0 3px 6px rgba(0,0,0,0.01); }
        .member-header { padding: 15px 18px; display: flex; justify-content: space-between; align-items: center; background: #fff; cursor: pointer; font-size: 14px; font-weight: 600; color: #333; user-select: none; transition: background 0.2s; }
        .member-header:hover { background: #fff5f6; color: #ff4d6d; }
        .member-header .arrow-icon { font-size: 12px; color: #aaa; transition: transform 0.2s; }
        .member-content { display: none; padding: 15px; background: #fdfcfc; border-top: 1px solid #f9f9f9; }
        .member-count-info { font-size: 12px; color: #b7094c; font-weight: 600; margin-bottom: 10px; padding-left: 2px; }
        .member-collapse-item.active .member-header { background: #fff0f3; color: #ff4d6d; }
        .member-collapse-item.active .arrow-icon { transform: rotate(180deg); color: #ff4d6d; }
        .member-collapse-item.active .member-content { display: block; }

        /* Chips hiển thị hoa */
        .chips-container { display: flex; flex-wrap: wrap; gap: 8px; }
        .chip { display: inline-block; padding: 6px 12px; border-radius: 12px; font-size: 12px; background: #fff; border: 1px solid #ffccd5; color: #a4133c; font-weight: 500; }
        
        /* KẾT QUẢ TÌM HOA ĐA DÒNG XẾP CHỒNG KHI SEARCH */
        .flower-result-container { display: flex; flex-direction: column; gap: 12px; width: 100%; }
        .summary-result { padding: 18px; border: 2px solid #ffccd5; border-radius: 20px; background: #fff5f6; color: #b7094c; font-size: 13px; line-height: 1.6; }
        .summary-result strong { color: #ff4d6d; font-weight: 700; }

        /* KHU VỰC NÚT BẤM CHÂN TRANG */
        .bottom-actions-section { margin-top: 25px; padding-top: 20px; border-top: 2px dashed #eee; display: flex; flex-direction: column; gap: 12px; }
        .btn-action { width: 100%; padding: 14px; background: #f8f9fa; border: 2px solid #e9ecef; border-radius: 15px; color: #495057; font-weight: 700; font-size: 13px; cursor: pointer; text-align: center; }
        
        .toggle-box { margin-top: 5px; padding: 15px; background: #fafafa; border: 1px dashed #dee2e6; border-radius: 15px; display: none; }
        .xu-missing-container { display: flex; flex-wrap: wrap; gap: 6px; }
        .xu-missing { display: inline-block; padding: 5px 11px; border-radius: 10px; font-size: 11px; background: #f8f9fa; border: 1px solid #dee2e6; color: #495057; font-weight: 500; }
    </style>
</head>
