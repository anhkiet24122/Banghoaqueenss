    function buildRankList() {
        mainRankArea.innerHTML = "";
        const totalMembers = membersData.length;
        let rankHtml = `<div class="member-count-badge">👥 Tổng số thành viên: ${totalMembers}</div>`;
        rankHtml += `<div class="rank-container">`;

        const sortedRank = membersData.map(m => {
            const uniqueCount = new Set(m.flowers).size;
            return { name: m.name, count: uniqueCount };
        }).sort((a, b) => b.count - a.count);

        sortedRank.forEach((item, index) => {
            const rankNum = index + 1;
            let rankClass = `rank-item`;
            if (rankNum === 1) rankClass += ' rank-top1';
            if (rankNum === 2) rankClass += ' rank-top2';
            if (rankNum === 3) rankClass += ' rank-top3';

            rankHtml += `
                <div class="${rankClass}">
                    <div class="rank-item-left">
                        <span class="rank-number">#${rankNum}</span>
                        <span>👑 ${item.name}</span>
                    </div>
                    <span class="rank-flower-count">${item.count} loại hoa</span>
                </div>
            `;
        });

        rankHtml += `</div>`;
        mainRankArea.innerHTML = rankHtml;
    }

    // 2. HÀM TẠO DANH SÁCH CHI TIẾT DẠNG ACCORDION
    function showAllMembersToArea(targetElement) {
        targetElement.innerHTML = "";
        membersData.forEach(m => {
            const uniqueFlowers = [...new Set(m.flowers)].sort((a, b) => a.localeCompare(b, 'vi'));
            
            const collapseItem = document.createElement('div');
            collapseItem.className = 'member-collapse-item';
            
            let chipsHtml = '';
            uniqueFlowers.forEach(f => { 
                chipsHtml += `<span class="chip">${capitalizeFirstLetter(f)}</span>`; 
            });

            collapseItem.innerHTML = `
                <div class="member-header">
                    <span>👑 ${m.name}</span>
                    <span class="arrow-icon">▼</span>
                </div>
                <div class="member-content">
                    <div class="member-count-info">✨ Sở hữu: ${uniqueFlowers.length} loại hoa</div>
                    <div class="chips-container">${chipsHtml}</div>
                </div>
            `;
            
            collapseItem.querySelector('.member-header').addEventListener('click', function() {
                collapseItem.classList.toggle('active');
            });
            
            targetElement.appendChild(collapseItem);
        });
    }

    // 3. LOGIC XỬ LÝ KHI GÕ Ô TÌM KIẾM TÊN HOA (ĐÃ FIX LỖI STYLE TRÙNG)
    function searchFlowerLogic() {
        const fKey = flowerInput.value.toLowerCase().trim();
        
        if (fKey !== "") {
            mainRankArea.style.display = "none";
            searchResultArea.style.display = "block";
            sectionTitle.innerText = "📋 Kết quả tìm kiếm theo tên hoa:";
            
            let matchedLowerSet = new Set();
            membersData.forEach(m => {
                m.flowers.forEach(f => { if (f.includes(fKey)) matchedLowerSet.add(f); });
            });
            xuFlowersList.forEach(xu => { if (xu.includes(fKey)) matchedLowerSet.add(xu); });

            const sortedMatches = Array.from(matchedLowerSet).sort((a, b) => a.localeCompare(b, 'vi'));

            if (sortedMatches.length > 0) {
                let htmlWrapper = '<div class="flower-result-container">';
                sortedMatches.forEach(lowerFlowerName => {
                    const ownersList = getOwnersOfFlower(lowerFlowerName);
                    let displayTitle = capitalizeFirstLetter(lowerFlowerName);
                    if (displayTitle.toLowerCase().startsWith("hoa ")) {
                        displayTitle = displayTitle.slice(4);
                        displayTitle = capitalizeFirstLetter(displayTitle);
                    }

                    if (ownersList.length > 0) {
                        htmlWrapper += `
                            <div class="summary-result">
                                🌸 Hoa <strong>${displayTitle}</strong> hiện có <strong>${ownersList.length}</strong> thành viên sở hữu:<br>
                                👉 <em>${ownersList.join(', ')}</em>
                            </div>`;
                    } else {
                        htmlWrapper += `
                            <div class="summary-result" style="color: #888; border-color: #dee2e6; background: #fafafa;">
                                🌸 Hoa <strong>${displayTitle}</strong>: Hiện chưa có thành viên nào sở hữu.
                            </div>`;
                    }
                });
                htmlWrapper += '</div>';
                searchResultArea.innerHTML = htmlWrapper;
            } else {
                searchResultArea.innerHTML = `<div class="summary-result" style="text-align:center; color:#999; background:#fafafa; border-color:#dee2e6;">❌ Không tìm thấy loại hoa nào chứa từ khóa "${flowerInput.value}"</div>`;
            }
        } else {
            searchResultArea.style.display = "none";
            mainRankArea.style.display = "block";
            sectionTitle.innerText = "📊 Bảng xếp hạng thành viên:";
        }
    }

    function updateMissingXu() {
        const ownedSet = new Set();
        membersData.forEach(m => m.flowers.forEach(f => ownedSet.add(f)));
        
        const missing = xuFlowersList.filter(xu => !ownedSet.has(xu));
        const uniqueMissing = [...new Set(missing)].sort((a, b) => a.localeCompare(b, 'vi'));
        
        missingArea.innerHTML = uniqueMissing.map(f => `<span class="xu-missing">${capitalizeFirstLetter(f)}</span>`).join('');
    }

    document.getElementById('btnMembers').addEventListener('click', function() {
        if (membersBox.style.display === "block") {
            membersBox.style.display = "none";
        } else {
            membersBox.style.display = "block";
            missingBox.style.display = "none"; 
            showAllMembersToArea(bottomMembersArea);
            setTimeout(() => { membersBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 80);
        }
    });

    document.getElementById('btnXu').addEventListener('click', function() {
        if (missingBox.style.display === "block") {
            missingBox.style.display = "none";
        } else {
            missingBox.style.display = "block";
            membersBox.style.display = "none"; 
            setTimeout(() => { missingBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 80);
        }
    });

    flowerInput.addEventListener('input', searchFlowerLogic);

    // Khởi tạo chạy ban đầu
    updateMissingXu();
    buildRankList();
    searchFlowerLogic();
</script>
</body>
</html>
