    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Be Vietnam Pro', sans-serif; }
        body { background: linear-gradient(135deg, #fdf6f7 0%, #ffeaf0 100%); color: #7a5961; padding: 30px 15px; display: flex; justify-content: center; min-height: 100vh; }
        .farm-container { width: 100%; max-width: 450px; background: rgba(255, 255, 255, 0.98); padding: 30px 25px; border-radius: 40px; box-shadow: 0 15px 35px rgba(255, 150, 170, 0.2); }
        .header-section { text-align: center; margin-bottom: 25px; }
        h2 { font-family: 'Lexend', sans-serif; color: #ff4d6d; font-size: 24px; }
        .search-group { position: relative; margin-bottom: 15px; }
        .search-label { font-size: 11px; font-weight: 700; color: #ff758f; margin-bottom: 5px; padding-left: 5px; }
        .farm-input { width: 100%; padding: 12px 20px; font-size: 14px; color: #5c4146; background: #fff5f6; border: 1px solid #ffccd5; border-radius: 25px; outline: none; transition: 0.3s; }
        .farm-input:focus { border-color: #ff4d6d; background: #fff; }
        .xu-btn { width: 100%; padding: 12px; font-weight: 700; background: #fff9e6; border: 1px solid #ffe599; color: #b57b00; border-radius: 25px; cursor: pointer; margin-bottom: 20px; transition: 0.3s; }
        .xu-btn:hover { background: #ffe599; transform: translateY(-2px); }
        .inventory-scroll { list-style: none; max-height: 400px; overflow-y: auto; padding-right: 5px; }
        .inventory-scroll::-webkit-scrollbar { width: 8px; }
        .inventory-scroll::-webkit-scrollbar-thumb { background: #ffafcc; border-radius: 10px; }
        .inventory-card { background: #ffffff; margin-bottom: 12px; padding: 18px; border-radius: 20px; border: 1px solid #ffe5ec; transition: 0.2s; }
        .inventory-card:hover { transform: scale(1.02); box-shadow: 0 8px 16px rgba(255, 150, 170, 0.15); }
        .card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .card-name { font-weight: 700; color: #ff4d6d; font-size: 14px; }
        .card-badge { font-size: 10px; background: #ffe5ec; padding: 3px 10px; border-radius: 15px; color: #ff4d6d; font-weight: 700; }
        .chips-container { display: flex; flex-wrap: wrap; gap: 6px; }
        .farm-chip { background-color: #fffafb; border: 1px solid #ffe5ec; color: #7a5961; padding: 4px 10px; border-radius: 12px; font-size: 11px; }
        .welcome-box { text-align: center; color: #a38087; font-size: 13px; padding: 40px 20px; }
    </style>
</head>
