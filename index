<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>🌸 Queenss Garden 👑</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Be Vietnam Pro', sans-serif; }
        body { background: #fdf6f7; padding: 20px; display: flex; justify-content: center; min-height: 100vh; }
        .farm-container { width: 100%; max-width: 500px; background: #fff; padding: 25px; border-radius: 30px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
        .card { padding: 20px; border: 1px solid #eee; border-radius: 20px; margin-top: 20px; }
        .chips-container { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
        .chip { padding: 6px 14px; border-radius: 15px; font-size: 12px; border: 1px solid #ffe5ec; color: #7a5961; }
        .chip-xu { padding: 6px 14px; border-radius: 15px; font-size: 12px; border: 2px solid #ffce54; background: #fff9e6; color: #b57b00; font-weight: 700; }
    </style>
</head>
<body>

<div class="farm-container">
    <h2>🌸 Tra cứu Thành viên Queenss</h2>
    <div id="displayArea"></div>
</div>

<script>
    // Danh sách Hoa Xu bạn cung cấp
    const xuFlowersList = [
        "Thục quỳ đỏ", "Thục quỳ hồng", "Thục quỳ vàng", "Thanh cúc lam", "Mạch môn tím", "Hoa sao nhái trắng", "Hoa baby trắng", "Hoa baby hồng", "Hoa baby lam", "Hoa lồng đèn đỏ", "Vạn tuế lá xanh", "Trúc đào đỏ tím", "Hải đường đỏ", "Hải đường vàng", "Đỗ quyên hồng", "Đỗ quyên vàng", "Đỗ quyên đỏ", "Tử linh lan hồng", "Tử linh lan đỏ", "Tử linh lan tím", "Hồng jacqueline trắng", "Hoa thúy châu tím", "Hoa thúy châu trắng", "Ghim cài lửa", "Ghim cài vàng mật", "Huệ hosta lam", "Hoa báo xuân hồng", "Hoa huyên tím trắng", "Hoa anh thảo tím nhạt", "Hoa anh thảo xanh nhạt", "Hoa anh thảo hồng nhạt", "Huệ hosta tím", "Mạn đà la", "Nhài nhật", "Lan phượng vĩ đỏ", "Mạch môn hồng phấn", "Hoa lộ vi vàng", "Hoa lộ vi trắng", "Cúc thược dược cam", "Cúc thược dược đen", "Lan vũ nữ vàng", "Hoa poppy himalaya vàng", "Hoa poppy himalaya xanh", "Hoa phi yến tím", "Hoa anh thảo vàng", "Hồng lenten vàng", "Cây sống đời đỏ", "Cây sống đời vàng", "Mộc hương vàng", "Mộc hương trắng", "Thược dược đỏ", "Lay ơn tím", "Tường vi hồng", "Lay ơn trắng", "Hải quỳ cam", "San hô tím", "San hô cam", "Hải quỳ đỏ", "Hoa hải quỳ tím", "Hoa hải quỳ hồng", "Hoa hải quỳ trắng", "Thược dược trắng", "Hồng môn phấn", "Thanh cúc tím", "Lạc tân phụ lam", "Lạc tân phụ đỏ", "Lạc tân phụ tím", "Tỏi trời", "Trúc đào hồng nhạt", "Địa lan trắng", "Hoa hành tím", "Diên đức vĩ trắng vàng", "Hồng lenten đỏ", "Mộc hương cam", "Vạn tuế lá lam"
    ];

    const membersData = [
        { 
            name: "Cá chiên (Anh Kiệt)", 
            flowers: ["Dạ yến thảo lam", "Hoa anh thảo hồng", "Lạp mai đỏ", "Hồng champagne", "Hoa hành tím", "Vạn tuế lá lam", "Diên đức vĩ trắng vàng", "Hồng Lenten đỏ", "Địa lan trắng", "Mộc hương cam", "Gấu bông", "Cây holly vòng xanh", "Bụp hồng cận hồng"] 
        }
    ];

    function toTitleCase(str) {
        return str.toLowerCase().split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
    }

    const container = document.getElementById('displayArea');
    membersData.forEach(m => {
        let html = `<div class="card"><h3>👑 ${m.name}</h3><div class="chips-container">`;
        
        m.flowers.forEach(f => {
            const formattedName = toTitleCase(f);
            // So sánh không phân biệt chữ hoa/thường
            const isXu = xuFlowersList.some(xu => xu.toLowerCase() === f.toLowerCase());
            const className = isXu ? "chip-xu" : "chip";
            html += `<span class="${className}">${formattedName}</span>`;
        });
        
        html += `</div></div>`;
        container.innerHTML += html;
    });
</script>
</body>
</html>
