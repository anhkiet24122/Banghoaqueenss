<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌸 Queenss Garden 👑</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Be Vietnam Pro', sans-serif; }
        body { background: #fdf6f7; padding: 20px; display: flex; justify-content: center; min-height: 100vh; }
        
        .farm-container { 
            width: 100%; 
            max-width: 500px; 
            background: #fff; 
            padding: 25px; 
            border-radius: 30px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.05); 
            display: flex; 
            flex-direction: column; 
        }
        
        h2 { text-align: center; margin-bottom: 25px; color: #ff4d6d; letter-spacing: 0.5px; font-size: 24px; }

        /* KHU VỰC Ô SEARCH ĐẸP MẮT */
        .search-box-pink { background: #fff5f6; border: 2px solid #ffccd5; padding: 14px; border-radius: 20px; margin-bottom: 15px; }
        .search-box-blue { background: #f0f7ff; border: 2px solid #bde0fe; padding: 14px; border-radius: 20px; margin-bottom: 25px; }
        .search-label { font-size: 11px; font-weight: 700; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
        .label-pink { color: #b7094c; }
        .label-blue { color: #003049; }
        
        .farm-input { 
            width: 100%; 
            padding: 12px 14px; 
            font-size: 14px; 
            border-radius: 12px; 
            border: 1px solid #ccc; 
            outline: none; 
            background: #fff; 
            color: #333; 
        }
        .farm-input:focus { border-color: #ff4d6d; }
        
        /* DANH SÁCH HIỂN THỊ THÀNH VIÊN BAN ĐẦU */
        .section-title { font-size: 13px; font-weight: 700; color: #495057; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 0.5px; }
        .members-section { flex-grow: 1; }
        
        .card { padding: 18px; border: 1px solid #f0f0f0; border-radius: 20px; margin-bottom: 15px; background: #fff; box-shadow: 0 4px 6px rgba(0,0,0,0.01); }
        .card h3 { font-size: 15px; color: #ff4d6d; margin-bottom: 12px; font-weight: 700; }
        .chips-container { display: flex; flex-wrap: wrap; gap: 8px; }
        .chip { display: inline-block; padding: 6px 12px; border-radius: 12px; font-size: 12px; background: #fff0f3; border: 1px solid #ffccd5; color: #a4133c; font-weight: 500; }
        
        /* KHU VỰC KẾT QUẢ TÌM HOA ĐA DÒNG XẾP CHỒNG QUÁ CHUẨN */
        .flower-result-container { display: flex; flex-direction: column; gap: 12px; width: 100%; }
        .summary-result { padding: 18px; border: 2px solid #ffccd5; border-radius: 20px; background: #fff5f6; color: #b7094c; font-size: 13px; line-height: 1.6; }
        .summary-result strong { color: #ff4d6d; font-weight: 700; }

        /* BẢNG HOA XU ĐÁY TRANG */
        .missing-section { margin-top: 30px; padding-top: 20px; border-top: 2px dashed #eee; }
        .btn-xu { width: 100%; padding: 14px; background: #f8f9fa; border: 2px solid #e9ecef; border-radius: 15px; color: #495057; font-weight: 700; font-size: 13px; cursor: pointer; text-align: center; }
        .missing-box { margin-top: 15px; padding: 15px; background: #fafafa; border: 1px dashed #dee2e6; border-radius: 15px; display: none; }
        .xu-missing-container { display: flex; flex-wrap: wrap; gap: 6px; }
        .xu-missing { display: inline-block; padding: 5px 11px; border-radius: 10px; font-size: 11px; background: #f8f9fa; border: 1px solid #dee2e6; color: #495057; font-weight: 500; }
    </style>
</head>
