    <style>
        /* Khung CSS cơ bản xử lý giao diện và logic ẩn hiện */
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Be Vietnam Pro', sans-serif; }
        body { 
            background: #fff0f3; 
            background-image: radial-gradient(#ffccd5 1.5px, transparent 1.5px);
            background-size: 20px 20px;
            padding: 30px 20px; 
            display: flex; 
            justify-content: center; 
            min-height: 100vh; 
        }
        /* Cấu trúc đóng mở hộp hoa của từng thành viên */
        .rank-content-box { display: none; padding: 18px; background: #fffdfd; border-top: 1px solid #fff0f2; }
        .active-folder .rank-content-box { display: block !important; }
        .active-folder .click-header-line { background: #fff0f3 !important; color: #ff4d6d !important; }
        
        /* Đồng bộ trạng thái mở rộng riêng cho các bạn Nam */
        .active-folder.gentleman-card-style .click-header-line { background: #e0f2fe !important; color: #003049 !important; }
        .active-folder.gentleman-card-style .rank-content-box { background: #fcfdfe !important; border-top-color: #bae6fd !important; }

        /* --- ĐỊNH DẠNG MÀU SẮC THEO 4 PHẨM CHẤT SỨC MẠNH --- */

        /* 1. PHẨM XANH LÁ */
        .tier-green { 
            background: linear-gradient(135deg, #ebfbee 0%, #cbf3d6) !important; 
            border: 1px solid #b7e4c7 !important; 
            color: #2d6a4f !important; 
            font-weight: 500;
        }

        /* 2. PHẨM TÍM */
        .tier-purple { 
            background: linear-gradient(135deg, #f3f0ff 0%, #eebefa) !important; 
            border: 1px solid #d0bfff !important; 
            color: #5f3dc4 !important; 
            font-weight: 500;
        }

        /* 3. PHẨM CAM */
        .tier-orange { 
            background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%) !important; 
            border: 1.5px solid #ff9800 !important; 
            color: #e65100 !important; 
            font-weight: 600 !important;
            box-shadow: 0 2px 5px rgba(255, 152, 0, 0.15) !important;
        }

        /* 4. PHẨM HỒNG */
        .tier-pink { 
            background: linear-gradient(135deg, #fff0f6 0%, #ffdeeb 100%) !important; 
            border: 2px solid #ff85a1 !important; 
            color: #a4133c !important; 
            font-weight: 700 !important;
            box-shadow: 0 3px 8px rgba(255, 133, 161, 0.3) !important;
        }

        .flower-chip-item { display: inline-block; padding: 6px 12px; border-radius: 14px; font-size: 11.5px; margin: 3px; }
        .xu-missing-badge { display: inline-block; padding: 6px 12px; border-radius: 14px; font-size: 11.5px; background: #fff; border: 1px solid #ffccd5; color: #a4133c; font-weight: 500; margin: 3px; }
        
        /* Dòng thống kê phẩm chất hiếm bên trong túi hoa */
        .summary-rarity-line {
            font-size: 12px;
            padding: 8px 12px;
            margin-bottom: 12px;
            border-radius: 12px;
            background: #fff5f6;
            border-left: 4px solid #ff4d6d;
            color: #4a4a4a;
            font-weight: 500;
            line-height: 1.5;
        }
        .gentleman-card-style .summary-rarity-line {
            background: #f0f9ff !important;
            border-left-color: #3b82f6 !important;
        }
    </style>
</head>
