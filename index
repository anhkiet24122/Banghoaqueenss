        /* Màu sắc phẩm chất */
        .tier-green { background: #cbf3d6; border: 1px solid #b7e4c7; color: #2d6a4f; }
        .tier-purple { background: #eebefa; border: 1px solid #d0bfff; color: #5f3dc4; }
        .tier-orange { background: #ffe0b2; border: 1.5px solid #ff9800; color: #e65100; }
        .tier-pink { background: #ffdeeb; border: 2px solid #ff85a1; color: #a4133c; }

        .flower-chip-item { display: inline-block; padding: 6px 12px; border-radius: 14px; font-size: 11.5px; margin: 3px; font-weight: 500; }
        .xu-missing-badge { display: inline-block; padding: 6px 12px; border-radius: 14px; font-size: 11.5px; background: #fff; border: 1px solid #ffccd5; color: #a4133c; font-weight: 500; margin: 3px; }
        .summary-rarity-line { font-size: 12px; padding: 8px 12px; margin-bottom: 12px; border-radius: 12px; background: #fff5f6; border-left: 4px solid #ff4d6d; color: #4a4a4a; font-weight: 500; }
    </style>
