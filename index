<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌸 Queenss Garden 👑</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Be Vietnam Pro', sans-serif; }
        body { background: #fdf6f7; padding: 15px; display: flex; justify-content: center; min-height: 100vh; }
        .farm-container { width: 100%; max-width: 450px; background: #fff; padding: 20px; border-radius: 25px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
        
        h2 { text-align: center; margin-bottom: 20px; color: #ff4d6d; }

        /* Tối ưu Input: Tự động xóa khi click */
        .farm-input { width: 100%; padding: 12px; border-radius: 12px; border: 2px solid #ddd; outline: none; transition: 0.3s; }
        .farm-input:focus { border-color: #ff4d6d; }
        
        .search-group { margin-bottom: 20px; }
        .section-title { font-size: 12px; font-weight: 700; color: #495057; margin-bottom: 10px; text-transform: uppercase; }

        /* Tối ưu hiển thị danh sách (Sắp xếp A-Z) */
        .owner-row { padding: 12px; border-bottom: 1px solid #f8f9fa; display: flex; justify-content: space-between; align-items: center; }
        .chip { font-size: 10px; background: #fff0f3; color: #a4133c; padding: 4px 8px; border-radius: 6px; border: 1px solid #ffccd5; }
        
        /* Tối ưu cuộn cho di động */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-thumb { background: #ffccd5; border-radius: 10px; }
    </style>
</head>
<body>

<div class="farm-container">
    <h2>🌸 Queenss Garden 👑</h2>
    
    <div class="search-group">
        <input type="text" id="flowerSearch" class="farm-input" placeholder="🌸 Tìm tên hoa...">
    </div>
    <div class="search-group">
        <input type="text" id="ownerSearch" class="farm-input" placeholder="👑 Tìm tên thành viên...">
    </div>
    
    <div class="section-title" id="sectionTitle">📋 Danh sách thành viên:</div>
    <div id="resultArea"></div>
</div>

<script>
    const membersData = [
        { name: "Cá chiên (Anh Kiệt)", flowers: ["Dạ yến thảo lam", "Hoa anh thảo hồng", "Lạp mai đỏ", "Hồng champagne", "Hoa hành tím"] },
        { name: "Tinkerbell (Cẩm Tiên cute)", flowers: ["Đăng tiêu trắng tím", "Đông trùng thông vàng", "Sen trời đầy sao", "Tuyết mai hồng"] }
    ];

    // Tính năng 1: Tự động xóa nội dung khi click vào
    document.querySelectorAll('.farm-input').forEach(input => {
        input.addEventListener('click', function() { this.value = ''; renderMembers(); });
    });

    function renderMembers() {
        const resultArea = document.getElementById('resultArea');
        resultArea.innerHTML = "";
        const fKey = document.getElementById('flowerSearch').value.toLowerCase();
        const oKey = document.getElementById('ownerSearch').value.toLowerCase();
        
        membersData.forEach(m => {
            // Tính năng 2: Sắp xếp hoa theo bảng chữ cái trước khi hiển thị
            let sortedFlowers = [...new Set(m.flowers)].sort((a, b) => a.localeCompare(b));
            
            const matchFlower = fKey ? sortedFlowers.some(f => f.toLowerCase().includes(fKey)) : true;
            const matchOwner = m.name.toLowerCase().includes(oKey);
            
            if (matchFlower && matchOwner) {
                let html = `<div class="owner-row"><span>${m.name}</span><div>`;
                sortedFlowers.filter(f => fKey ? f.toLowerCase().includes(fKey) : true)
                             .forEach(f => html += `<span class="chip">${f}</span> `);
                resultArea.innerHTML += html + `</div></div>`;
            }
        });
    }

    document.getElementById('flowerSearch').addEventListener('input', renderMembers);
    document.getElementById('ownerSearch').addEventListener('input', renderMembers);
    renderMembers();
</script>
</body>
</html>
