        { name: "Mộng khiết (Yến Ly)", flowers: ["Cây holly vòng xanh", "Dạ yến thảo lam", "Hoa anh thảo hồng", "Hồng champagne", "Mạch môn hồng phấn", "Hoa lộ vi trắng", "Hồng môn phấn", "Mạn đà la", "Hải quỳ cam", "Mộc hương trắng", "San hô cam", "Lay ơn trắng", "Gấu bông", "Bụp hồng cận hồng"] },
        { name: "Hải Đường (Thanh Ngân)", flowers: ["Trái tim đá quý", "Mộc lan ngọc ngà", "Cá heo hồng", "Hoa hành tím", "Lan phượng vĩ đỏ", "Hoa poppy himalaya xanh", "San hô tím", "Hoa poppy tím", "Hoa lồng đèn cam", "Lan vũ nữ cam", "Dạ yến thảo lam", "Hồng champagne", "Cúc thược dược cam", "Gấu bông", "Cây holly vòng xanh", "Bụp hồng cận hồng", "Hoa anh thảo hồng", "Hoa anh thảo xanh", "Ngôi sao bethlehem"] },
        { name: "Mina (Mỹ Anh)", flowers: ["Ngân hà chiếu nhụy", "Mộc lan ngọc ngà", "Dạ yến thảo lam", "Hoa anh thảo hồng", "Lạp mai đỏ", "Hồng champagne", "Địa lan trắng", "Mạn đà la", "San hô tím", "Hoa poppy cam", "Thược dược trắng", "Lay ơn tím", "Gấu bông", "Cây holly vòng xanh", "Bụp hồng cận hồng", "Lạc tân phụ lam", "Lạc tân phụ đỏ", "Thanh cúc tím", "Thanh cúc hồng", "Lạc tân phụ tím", "Tỏi trời"] }
    ];

    const xuFlowersList = rawXuList.map(item => cleanFormat(item));
    const membersData = rawMembers.map(m => ({
        name: m.name,
        flowers: m.flowers.map(f => cleanFormat(f))
    }));

    const mainRankArea = document.getElementById('mainRankArea');
    const searchResultArea = document.getElementById('searchResultArea');
    const missingArea = document.getElementById('missingArea');
    const missingBox = document.getElementById('missingBox');
    const rankBox = document.getElementById('rankBox');
    const flowerInput = document.getElementById('flowerSearch');
    const defaultGardenWidgets = document.getElementById('defaultGardenWidgets');
    const searchViewArea = document.getElementById('searchViewArea');

    function getOwnersOfFlower(lowerFlowerName) {
        return membersData.filter(m => m.flowers.includes(lowerFlowerName)).map(m => m.name);
    }

    // TẠO BẢNG XẾP HẠNG TÍCH HỢP ĐÓNG MỞ HOA ĐỘC LẬP
    function buildRankList() {
        mainRankArea.innerHTML = "";
        
        const totalMembers = membersData.length;
        mainRankArea.innerHTML = `<div class="member-count-badge">👥 Tổng số thành viên: ${totalMembers}</div>`;
        
        const container = document.createElement('div');
        container.className = 'rank-container';

        const sortedRank = membersData.map(m => {
            const uniqueFlowers = [...new Set(m.flowers)].sort((a, b) => a.localeCompare(b, 'vi'));
            return { name: m.name, rawFlowers: uniqueFlowers, count: uniqueFlowers.length };
        }).sort((a, b) => b.count - a.count);

        sortedRank.forEach((item, index) => {
            const rankNum = index + 1;
            const collapseItem = document.createElement('div');
            
            let rankClass = `rank-collapse-item`;
            if (rankNum === 1) rankClass += ' rank-top1';
            if (rankNum === 2) rankClass += ' rank-top2';
            if (rankNum === 3) rankClass += ' rank-top3';
            collapseItem.className = rankClass;

            let chipsHtml = '';
            item.rawFlowers.forEach(f => {
                chipsHtml += `<span class="chip">${capitalizeFirstLetter(f)}</span>`;
            });

            collapseItem.innerHTML = `
                <div class="rank-header">
                    <div class="rank-item-left">
                        <span class="rank-number">#${rankNum}</span>
                        <span>👑 ${item.name}</span>
                    </div>
                    <span class="rank-flower-count">${item.count} loại hoa</span>
                </div>
                <div class="rank-content">
                    <div class="chips-container">${chipsHtml}</div>
                </div>
            `;

            collapseItem.querySelector('.rank-header').addEventListener('click', function() {
                collapseItem.classList.toggle('active');
            });

            container.appendChild(collapseItem);
        });

        mainRankArea.appendChild(container);
    }

    // LOGIC KHI GÕ TÌM KIẾM TÊN HOA
    function searchFlowerLogic() {
        const fKey = flowerInput.value.toLowerCase().trim();
        
        if (fKey !== "") {
            // Khi gõ ô search -> Ẩn toàn bộ nút bấm ở màn hình chính, bật chế độ xem kết quả tìm hoa
            defaultGardenWidgets.style.display = "none";
            searchViewArea.style.display = "block";
            
            let matchedLowerSet = new Set();
            membersData.forEach(m => {
                m.flowers.forEach(f => { if (f.includes(fKey)) matchedLowerSet.add(f); });
            });
            xuFlowersList.forEach(xu => { if (xu.includes(fKey)) matchedLowerSet.add(xu); });

            const sortedMatches = Array.from(matchedLowerSet).sort((a, b) => a.localeCompare(b, 'vi'));

            if (sortedMatches.length > 0) {
                let htmlWrapper = '<div class="flower-result-container">';
                sortedMatches.forEach(lowerFlowerName => {
                    const ownersList = getOwnersOfFlower(lowerFlowerName);
                    let displayTitle = capitalizeFirstLetter(lowerFlowerName);
                    if (displayTitle.toLowerCase().startsWith("hoa ")) {
                        displayTitle = displayTitle.slice(4);
                        displayTitle = capitalizeFirstLetter(displayTitle);
                    }

                    if (ownersList.length > 0) {
                        htmlWrapper += `
                            <div class="summary-result">
                                🌸 Hoa <strong>${displayTitle}</strong> hiện có <strong>${ownersList.length}</strong> thành viên sở hữu:<br>
                                👉 <em>${ownersList.join(', ')}</em>
                            </div>`;
                    } else {
                        htmlWrapper += `
                            <div class="summary-result" style="color: #888; border-color: #dee2e6; background: #fafafa;">
                                🌸 Hoa <strong>${displayTitle}</strong>: Hiện chưa có thành viên nào sở hữu.
                            </div>`;
                    }
                });
                htmlWrapper += '</div>';
                searchResultArea.innerHTML = htmlWrapper;
            } else {
                searchResultArea.innerHTML = `<div class="summary-result" style="text-align:center; color:#999; background:#fafafa; border-color:#dee2e6;">❌ Không tìm thấy loại hoa nào chứa từ khóa "${flowerInput.value}"</div>`;
            }
        } else {
            // Khi ô search trống -> Hiện lại toàn bộ nút bấm, ẩn vùng xem kết quả tìm kiếm đi
            searchViewArea.style.display = "none";
            defaultGardenWidgets.style.display = "flex";
        }
    }

    function updateMissingXu() {
        const ownedSet = new Set();
        membersData.forEach(m => m.flowers.forEach(f => ownedSet.add(f)));
        
        const missing = xuFlowersList.filter(xu => !ownedSet.has(xu));
        const uniqueMissing = [...new Set(missing)].sort((a, b) => a.localeCompare(b, 'vi'));
        
        missingArea.innerHTML = uniqueMissing.map(f => `<span class="xu-missing">${capitalizeFirstLetter(f)}</span>`).join('');
    }

    // Sự kiện nút bật tắt BXH rút gọn
    document.getElementById('btnRank').addEventListener('click', function() {
        if (rankBox.style.display === "block") {
            rankBox.style.display = "none";
        } else {
            rankBox.style.display = "block";
            missingBox.style.display = "none"; 
            buildRankList();
            setTimeout(() => { rankBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 80);
        }
    });

    // Sự kiện nút bật tắt danh sách Hoa Xu
    document.getElementById('btnXu').addEventListener('click', function() {
        if (missingBox.style.display === "block") {
            missingBox.style.display = "none";
        } else {
            missingBox.style.display = "block";
            rankBox.style.display = "none"; 
            setTimeout(() => { missingBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 80);
        }
    });

    flowerInput.addEventListener('input', searchFlowerLogic);

    // Chạy mặc định ban đầu
    updateMissingXu();
    searchFlowerLogic();
</script>
</body>
