<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌸 Queenss Garden 👑</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Be Vietnam Pro', sans-serif; }
        body { 
            background: #fdf6f7; 
            padding: 20px; 
            display: flex; 
            justify-content: center; 
            min-height: 100vh; 
            transition: background 0.4s;
        }
        
        .farm-container { 
            width: 100%; 
            max-width: 520px; 
            background: #fff; 
            padding: 25px; 
            border-radius: 30px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.08); 
            display: flex; 
            flex-direction: column; 
            transition: all 0.4s;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        h2 { 
            color: #ff4d6d; 
            letter-spacing: 0.5px; 
            font-size: 24px; 
        }

        .dark-mode .farm-container { background: #1e1e2e; color: #e0e0e0; }
        .dark-mode body { background: #12121a; }
        .dark-mode h2 { color: #ff6b8a; }

        /* Search */
        .search-box-pink { background: #fff5f6; border: 2px solid #ffccd5; padding: 14px; border-radius: 20px; margin-bottom: 12px; }
        .search-box-blue { background: #f0f7ff; border: 2px solid #bde0fe; padding: 14px; border-radius: 20px; margin-bottom: 20px; }
        .dark-mode .search-box-pink { background: #2a1f24; border-color: #c2255c; }
        .dark-mode .search-box-blue { background: #1e2a3a; border-color: #4a8cff; }

        .search-label { font-size: 11px; font-weight: 700; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
        .label-pink { color: #b7094c; }
        .label-blue { color: #003049; }
        .dark-mode .label-pink { color: #ff6b8a; }
        .dark-mode .label-blue { color: #7ab3ff; }

        .farm-input { 
            width: 100%; 
            padding: 12px 14px; 
            font-size: 14px; 
            border-radius: 12px; 
            border: 1px solid #ccc; 
            outline: none; 
            background: #fff; 
            color: #333; 
        }
        .dark-mode .farm-input { background: #2a2a3a; border-color: #555; color: #eee; }

        .clear-btn {
            margin-left: 8px;
            background: none;
            border: none;
            font-size: 18px;
            cursor: pointer;
            color: #999;
        }

        /* Stats */
        .stats {
            background: #fff0f5;
            padding: 14px;
            border-radius: 18px;
            margin-bottom: 20px;
            font-size: 13px;
            text-align: center;
            border: 1px solid #ffc2d1;
        }
        .dark-mode .stats { background: #2a1f24; border-color: #6b2a44; }

        /* Members */
        .section-title { 
            font-size: 13px; 
            font-weight: 700; 
            color: #495057; 
            margin: 20px 0 12px; 
            text-transform: uppercase; 
            letter-spacing: 0.5px; 
        }

        .card { 
            padding: 18px; 
            border: 1px solid #f0f0f0; 
            border-radius: 20px; 
            margin-bottom: 15px; 
            background: #fff; 
            box-shadow: 0 4px 10px rgba(0,0,0,0.04);
            transition: transform 0.2s;
        }
        .card:hover { transform: translateY(-3px); }
        .dark-mode .card { background: #2a2a3a; border-color: #444; }

        .card h3 { 
            font-size: 15px; 
            color: #ff4d6d; 
            margin-bottom: 12px; 
            font-weight: 700; 
        }
        .dark-mode .card h3 { color: #ff8ba7; }

        .chips-container { display: flex; flex-wrap: wrap; gap: 8px; }
        .chip { 
            display: inline-block; 
            padding: 6px 12px; 
            border-radius: 12px; 
            font-size: 12px; 
            background: #fff0f3; 
            border: 1px solid #ffccd5; 
            color: #a4133c; 
            font-weight: 500; 
        }
        .dark-mode .chip { background: #3a2a2f; border-color: #c2255c; color: #ff9eb8; }

        /* Flower Result */
        .flower-result-container { display: flex; flex-direction: column; gap: 12px; }
        .summary-result { 
            padding: 18px; 
            border: 2px solid #ffccd5; 
            border-radius: 20px; 
            background: #fff5f6; 
            color: #b7094c; 
            font-size: 13.5px; 
            line-height: 1.6;
            position: relative;
            overflow: hidden;
        }
        .summary-result::before {
            content: "🌸";
            position: absolute;
            right: -25px;
            top: -25px;
            font-size: 70px;
            opacity: 0.08;
        }
        .dark-mode .summary-result { 
            background: #2a1f24; 
            border-color: #c2255c; 
            color: #ff9eb8; 
        }

        /* Missing */
        .missing-section { margin-top: 30px; padding-top: 20px; border-top: 2px dashed #eee; }
        .btn-xu { 
            width: 100%; 
            padding: 14px; 
            background: #f8f9fa; 
            border: 2px solid #e9ecef; 
            border-radius: 15px; 
            color: #495057; 
            font-weight: 700; 
            font-size: 13px; 
            cursor: pointer; 
        }
        .dark-mode .btn-xu { background: #2a2a3a; border-color: #555; color: #ddd; }

        .missing-box { 
            margin-top: 15px; 
            padding: 15px; 
            background: #fafafa; 
            border: 1px dashed #dee2e6; 
            border-radius: 15px; 
            display: none; 
        }
        .xu-missing-container { display: flex; flex-wrap: wrap; gap: 6px; }
        .xu-missing { 
            display: inline-block; 
            padding: 5px 11px; 
            border-radius: 10px; 
            font-size: 11px; 
            background: #f8f9fa; 
            border: 1px solid #dee2e6; 
            color: #495057; 
            font-weight: 500; 
        }
        .dark-mode .missing-box { background: #1e1e2e; border-color: #444; }
        .dark-mode .xu-missing { background: #2a2a3a; border-color: #555; color: #ccc; }
    </style>
</head>
