                        <span>${icon} ${item.name}</span>
                    </div>
                    <span class="rank-badge-pill" style="font-weight: 700; padding: 5px 12px; border-radius: 20px; font-size: 11px; ${badgeColorStyle}">${item.count} loại hoa</span>
                </div>
                <div class="rank-content-box">
                    ${summaryHtml}
                    <div style="display: flex; flex-wrap: wrap; gap: 4px;">${chipsHtml}</div>
                </div>
            `;

            collapseItem.querySelector('.click-header-line').addEventListener('click', function() {
                collapseItem.classList.toggle('active-folder');
            });

            container.appendChild(collapseItem);
        });

        mainRankArea.appendChild(container);
    }

    function searchFlowerLogic() {
        const fKey = flowerInput.value.toLowerCase().trim();
        
        if (fKey !== "") {
            defaultGardenWidgets.style.display = "none";
            searchViewArea.style.display = "block";
            
            let matchedLowerSet = new Set();
            membersData.forEach(m => {
                m.flowers.forEach(f => { if (f.includes(fKey)) matchedLowerSet.add(f); });
            });
            xuFlowersList.forEach(xu => { if (xu.includes(fKey)) matchedLowerSet.add(xu); });

            const sortedMatches = Array.from(matchedLowerSet).sort((a, b) => a.localeCompare(b, 'vi'));

            if (sortedMatches.length > 0) {
                let htmlWrapper = '<div class="flower-stacked-results" style="display: flex; flex-direction: column; gap: 14px; width: 100%;">';
                sortedMatches.forEach(lowerFlowerName => {
                    const ownersList = getOwnersOfFlower(lowerFlowerName);
                    let displayTitle = capitalizeFirstLetter(lowerFlowerName);
                    if (displayTitle.toLowerCase().startsWith("hoa ")) {
                        displayTitle = displayTitle.slice(4);
                        displayTitle = capitalizeFirstLetter(displayTitle);
                    }

                    if (ownersList.length > 0) {
                        htmlWrapper += `
                            <div class="single-flower-block" style="padding: 18px; border: 2.5px solid #ffccd5; border-radius: 24px; background: #fff5f6; color: #b7094c; font-size: 13.5px; line-height: 1.6; box-shadow: 0 6px 15px rgba(255,182,193,0.12);">
                                🌸 Hoa <strong>${displayTitle}</strong> hiện có <strong>${ownersList.length}</strong> thành viên sở hữu:<br>
                                👉 <em>${ownersList.join(', ')}</em>
                            </div>`;
                    } else {
                        htmlWrapper += `
                            <div class="single-flower-block" style="padding: 18px; border: 2.5px solid #dee2e6; border-radius: 24px; background: #fafafa; color: #888; font-size: 13.5px; line-height: 1.6;">
                                🌸 Hoa <strong>${displayTitle}</strong>: Hiện chưa có thành viên nào sở hữu.
                            </div>`;
                    }
                });
                htmlWrapper += '</div>';
                searchResultArea.innerHTML = htmlWrapper;
            } else {
                searchResultArea.innerHTML = `<div class="single-flower-block" style="padding: 18px; border: 2.5px solid #dee2e6; border-radius: 24px; background: #fafafa; color: #999; text-align:center; font-size: 13.5px;">❌ Không tìm thấy loại hoa nào chứa từ khóa "${flowerInput.value}"</div>`;
            }
        } else {
            searchViewArea.style.display = "none";
            defaultGardenWidgets.style.display = "flex";
        }
    }

    function updateMissingXu() {
        const ownedSet = new Set();
        membersData.forEach(m => m.flowers.forEach(f => ownedSet.add(f)));
        const missing = xuFlowersList.filter(xu => !ownedSet.has(xu));
        const uniqueMissing = [...new Set(missing)].sort((a, b) => a.localeCompare(b, 'vi'));
        missingArea.innerHTML = uniqueMissing.map(f => `<span class="xu-missing-badge">${capitalizeFirstLetter(f)}</span>`).join('');
    }

    document.getElementById('btnHelp').addEventListener('click', function() {
        if (helpBox.style.display === "block") {
            helpBox.style.display = "none";
        } else {
            helpBox.style.display = "block";
            rankBox.style.display = "none";
            missingBox.style.display = "none";
            setTimeout(() => { helpBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 80);
        }
    });

    document.getElementById('btnRank').addEventListener('click', function() {
        if (rankBox.style.display === "block") {
            rankBox.style.display = "none";
        } else {
            rankBox.style.display = "block";
            helpBox.style.display = "none";
            missingBox.style.display = "none"; 
            setTimeout(() => { rankBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 80);
        }
    });

    document.getElementById('btnXu').addEventListener('click', function() {
        if (missingBox.style.display === "block") {
            missingBox.style.display = "none";
        } else {
            missingBox.style.display = "block";
            helpBox.style.display = "none";
            rankBox.style.display = "none"; 
            setTimeout(() => { missingBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 80);
        }
    });

    initRenderRankList();
    flowerInput.addEventListener('input', searchFlowerLogic);
    updateMissingXu();
</script>
</body>
</html>
