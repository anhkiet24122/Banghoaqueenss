        { name: "Henniken (Hương)", flowers: ["Hạc gửi ngân hà", "Hoa hành tím", "Lan phượng vĩ đỏ", "Hồng môn phấn", "Lay ơn trắng", "Cây holly vòng xanh", "Bụp hồng cận hồng", "Dạ yến thảo lam", "Lạp mai đỏ", "Tường vi hồng"] },
        { name: "Thời Khanh (Trúc Linh)", flowers: ["Ngân Hà Chiếu Nhụy", "Cúc mẫu đơn tím nho", "Cây holly vòng xanh", "Bụp hồng cận hồng", "Dạ yến thảo lam", "Hồng champagne", "Ngôi sao bethlehem", "Gấu bông", "Ghim cài lửa", "Tử linh lan đỏ", "Lạc tân phụ tím", "Lạc tân phụ đỏ", "Thanh cúc tím", "Lạc tân phụ lam"] },
        { name: "Sun (Thắng)", flowers: ["Cúc indo cam", "Gấu bông", "Cây holly vòng xanh", "Bụp hồng cận hồng", "Đông trùng thông vàng", "Hoa mặt rồng hồng phấn", "Dạ yến thảo lam", "Hoa anh thảo xanh", "Lạp mai đỏ", "Mạn châu sa", "San hô xanh", "Ngôi sao bethlehem", "Vạn tuế lá lam", "Hồng lenten vàng", "Hồng môn phấn", "Trái tim mộng ảo", "Mộc lan ngọc ngà", "Sách mai điệp ảnh", "Gấu hoa hồng", "Cừu bông ngọt ngào", "Trái tim tìm mật"] },
        { name: "Tiểu linh nhi (Gia Linh)", flowers: ["Cây holly vòng xanh", "Bụp hồng cận hồng", "Thục quỳ đỏ", "Lạc tân phụ đỏ", "Lạc tân phụ tím", "Thục quỳ hồng"] }
    ].map(m => ({ ...m, flowers: m.flowers.map(clean) }));

    const getWeight = (name) => {
        const n = name.toLowerCase().trim();
        if (n.includes("sao nhái tím")) return { score: 2, className: 'tier-purple' };
        if (PINK_LIST.includes(n)) return { score: 4, className: 'tier-pink' };
        if (ORANGE_LIST.includes(n)) return { score: 3, className: 'tier-orange' };
        if (GREEN_LIST.includes(n)) return { score: 1, className: 'tier-green' };
        return { score: 2, className: 'tier-purple' };
    };

    const toggle = (id, box) => {
        const isOpen = document.getElementById(box).style.display === 'block';
        ['helpBox', 'rankBox', 'missingBox'].forEach(b => document.getElementById(b).style.display = 'none');
        document.getElementById(box).style.display = isOpen ? 'none' : 'block';
    };

    document.getElementById('btnHelp').onclick = () => toggle('btnHelp', 'helpBox');
    document.getElementById('btnRank').onclick = () => {
        toggle('btnRank', 'rankBox');
        const area = document.getElementById('mainRankArea');
        area.innerHTML = '';
        membersData.map(m => ({ ...m, unique: [...new Set(m.flowers)] })).sort((a,b) => b.unique.length - a.unique.length).forEach((m, i) => {
            const div = document.createElement('div');
            div.className = (m.name.includes("Cá chiên") || m.name.includes("Sun")) ? 'active-folder gentleman-card-style' : 'active-folder';
            const sorted = m.unique.map(f => ({ name: f, ...getWeight(f) })).sort((a,b) => b.score - a.score);
            let pink=0, orange=0, purple=0, green=0;
            sorted.forEach(f => { if(f.score==4) pink++; if(f.score==3) orange++; if(f.score==2) purple++; if(f.score==1) green++; });
            div.innerHTML = `<div class="click-header-line" style="padding:15px; cursor:pointer;">#${i+1} ${m.name} (${m.unique.length})</div>
                             <div class="rank-content-box"><div class="summary-rarity-line">👑 ${pink} Hồng | ${orange} Cam | ${purple} Tím | ${green} Xanh</div>
                             ${sorted.map(f => `<span class="flower-chip-item ${f.className}">${cap(f.name)}</span>`).join('')}</div>`;
            div.querySelector('.click-header-line').onclick = () => div.classList.toggle('active-folder');
            area.appendChild(div);
        });
    };
    document.getElementById('btnXu').onclick = () => {
        toggle('btnXu', 'missingBox');
        const owned = new Set(membersData.flatMap(m => m.flowers));
        document.getElementById('missingArea').innerHTML = [...new Set(rawXuList.map(clean))].filter(x => !owned.has(x)).sort().map(f => `<span class="xu-missing-badge">${cap(f)}</span>`).join('');
    };
</script>
</body>
</html>
